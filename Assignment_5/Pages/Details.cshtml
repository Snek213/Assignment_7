@page "{id:int}"
@model Assignment_7.Pages.DetailsModel
@{
    ViewData["Title"] = "Movie Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.Movie.PictureUri))
            {
                <img src="@Model.Movie.PictureUri" class="img-fluid rounded" alt="@Model.Movie.Title">
            }
            else
            {
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height: 400px;">
                    <span>No Image Available</span>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h1 class="mb-3">@Model.Movie.Title</h1>
            
            <div class="mb-3">
                <h4 class="text-primary">$@Model.Movie.Price</h4>
            </div>

            <div class="mb-3">
                <!--Strong property makes bolded text-->
                <strong>Rating:</strong> @Model.Movie.Rating / 100
            </div>

            <div class="mb-3">
                <strong>Release Date:</strong> @Model.Movie.ReleaseDate.ToString("MM/dd/yyyy")
            </div>

            <div class="mb-4">
                <strong>Genre:</strong> @Model.Movie.Genre
            </div>

            <div class="d-flex gap-2">
                <a asp-page="/Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                <button type="button" class="btn btn-primary">
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
            </div>
        </div>
    </div>
</div>
